generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  phone          String?
  businessName   String
  passwordHash   String
  role           Role       @default(USER)
  status         UserStatus @default(PENDING)
  resetToken            String?    @unique
  resetTokenExpiry      DateTime?
  emailVerified         Boolean    @default(false)
  verificationCode      String?
  verificationCodeExpiry DateTime?
  businessCategory    String?
  businessDescription String?
  businessAddress     String?
  businessEmail       String?
  businessWebsite     String?
  maxAgents          Int        @default(1)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  agents             Agent[]
  leads              Lead[]
  conversationReads  ConversationRead[]
}

model Agent {
  id                   String      @id @default(cuid())
  userId               String
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName         String
  businessDescription  String      @db.Text
  productsServices     String      @db.Text
  faqs                 String      @db.Text
  operatingHours       String
  contactEmail         String?
  contactPhone         String?
  websiteLinks         String?
  responseGuidelines   String?     @db.Text
  profileImageUrl      String?
  whatsappBusinessName String?
  whatsappAgentLink    String?
  whatsappPhoneNumber  String?
  qrCodeUrl            String?
  elevenlabsAgentId    String?
  category             String?
  address              String?
  productsData         Json?
  toolsData            Json?
  status               AgentStatus @default(PENDING_REVIEW)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  leads                Lead[]
  conversationLogs     ConversationLog[]
  customers            Customer[]
}

model Lead {
  id             String     @id @default(cuid())
  conversationId String
  agentId        String
  userId         String
  callerNumber   String?
  summary        String?    @db.Text
  status         LeadStatus @default(NEW)
  notes          String?    @db.Text
  aiDetected     Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  agent          Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model ConversationRead {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  readAt         DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum AgentStatus {
  PENDING_REVIEW
  SETTING_UP
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
}

model Customer {
  id                  String    @id @default(cuid())
  phoneNumber         String    @unique
  agentId             String?
  name                String?
  email               String?
  conversationSummary String?   @db.Text
  lastSeen            DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  agent               Agent?           @relation(fields: [agentId], references: [id], onDelete: SetNull)
  conversationLogs    ConversationLog[]
}

model ConversationLog {
  id                String    @id @default(cuid())
  conversationId    String    @unique
  elevenlabsAgentId String
  agentId           String?
  customerId        String?
  phoneNumber       String?
  transcript        Json
  summary           String?   @db.Text
  durationSecs      Int?
  startTime         DateTime?
  status            String?
  rawPayload        Json
  createdAt         DateTime  @default(now())

  agent             Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
}
