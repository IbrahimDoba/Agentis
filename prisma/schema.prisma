generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  phone          String?
  businessName   String
  passwordHash   String?
  role           Role       @default(USER)
  status         UserStatus @default(PENDING)
  workspaceMembers   WorkspaceMember[] @relation("WorkspaceOwner")
  memberOf           WorkspaceMember[] @relation("WorkspaceMemberUser")
  resetToken            String?    @unique
  resetTokenExpiry      DateTime?
  emailVerified         Boolean    @default(false)
  verificationCode      String?
  verificationCodeExpiry DateTime?
  businessCategory    String?
  businessDescription String?
  businessAddress     String?
  businessEmail       String?
  businessWebsite     String?
  maxAgents               Int        @default(1)
  plan                    String     @default("free")
  subscriptionExpiresAt   DateTime?
  onboardingCompleted     Boolean    @default(false)
  referralsEnabled    Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  agents             Agent[]
  leads              Lead[]
  conversationReads  ConversationRead[]
  referralCode       String?    @unique
  referralsMade      Referral[] @relation("ReferralsMade")
  referredBy         Referral?  @relation("ReferredBy")
  paymentRequests    PaymentRequest[]
}

model Agent {
  id                   String      @id @default(cuid())
  userId               String
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName         String
  businessDescription  String      @db.Text
  productsServices     String      @db.Text
  faqs                 String      @db.Text
  operatingHours       String
  contactEmail         String?
  contactPhone         String?
  websiteLinks         String?
  responseGuidelines   String?     @db.Text
  profileImageUrl      String?
  whatsappBusinessName String?
  whatsappAgentLink    String?
  whatsappPhoneNumber  String?
  qrCodeUrl            String?
  elevenlabsAgentId    String?
  whatsappPhoneNumberId String?
  messagingEnabled     Boolean     @default(true)
  category             String?
  address              String?
  productsData         Json?
  toolsData            Json?
  status               AgentStatus @default(PENDING_REVIEW)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  leads                Lead[]
  conversationLogs     ConversationLog[]
  customers            Customer[]
  templates            MessageTemplate[]
}

model MessageTemplate {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name      String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id             String     @id @default(cuid())
  conversationId String
  agentId        String
  userId         String
  callerNumber   String?
  summary        String?    @db.Text
  status         LeadStatus @default(NEW)
  notes          String?    @db.Text
  aiDetected     Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  agent          Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model ConversationRead {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  readAt         DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum AgentStatus {
  PENDING_REVIEW
  SETTING_UP
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
}

model Customer {
  id                  String    @id @default(cuid())
  phoneNumber         String    @unique
  agentId             String?
  name                String?
  email               String?
  conversationSummary String?   @db.Text
  lastSeen            DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  agent               Agent?           @relation(fields: [agentId], references: [id], onDelete: SetNull)
  conversationLogs    ConversationLog[]
}

model Referral {
  id               String         @id @default(cuid())
  referrerId       String
  referredId       String         @unique
  code             String?
  status           ReferralStatus @default(PENDING)
  commissionRate   Float          @default(0.15)
  commissionEarned Float?
  rewardGranted    Boolean        @default(false)
  assignedByAdmin  Boolean        @default(false)
  createdAt        DateTime       @default(now())

  referrer         User           @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referred         User           @relation("ReferredBy", fields: [referredId], references: [id], onDelete: Cascade)
}

enum ReferralStatus {
  PENDING
  COMPLETED
  REWARDED
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?
  createdAt DateTime @default(now())
}

model ConversationLog {
  id                String    @id @default(cuid())
  conversationId    String    @unique
  elevenlabsAgentId String
  agentId           String?
  customerId        String?
  phoneNumber       String?
  transcript        Json
  summary           String?   @db.Text
  durationSecs      Int?
  startTime         DateTime?
  status            String?
  creditsUsed       Int       @default(0)
  rawPayload        Json
  createdAt         DateTime  @default(now())

  agent             Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
}

model WorkspaceMember {
  id          String              @id @default(cuid())
  workspaceId String
  userId      String?
  email       String
  role        WorkspaceRole       @default(MEMBER)
  status      WorkspaceInviteStatus @default(PENDING)
  inviteToken String?             @unique
  invitedAt   DateTime            @default(now())
  joinedAt    DateTime?

  workspace   User                @relation("WorkspaceOwner", fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?               @relation("WorkspaceMemberUser", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, email])
}

enum WorkspaceRole {
  ADMIN
  MEMBER
}

enum WorkspaceInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model PaymentRequest {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        String
  amountNaira Int
  status      PaymentStatus @default(PENDING)
  reference   String        @unique @default(cuid())
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
